# Copy only the variables required by the profile you run into your local `.env`.
# Your file real `environment file` must be with extension `.env` not `.env.example`
# Never commit real secrets, production credentials, or personal API keys.

# Runtime tuning for the JVM process.
# Limits heap usage relative to container memory, enables G1GC, and exits on OOM.

JAVA_TOOL_OPTIONS=-XX:MaxRAMPercentage=65.0 -XX:+UseG1GC -XX:+ExitOnOutOfMemoryError

# Application ports.
# SERVER_PORT exposes the main API; MANAGEMENT_SERVER_PORT exposes actuator/health endpoints.

SERVER_PORT=8080
MANAGEMENT_SERVER_PORT=9090

# Google GenAI integration used by Spring AI.
# Required for features that call Gemini models.

SPRING_AI_GOOGLE_GENAI_API_KEY=your-google-genai-api-key
SPRING_AI_GOOGLE_GENAI_CHAT_MODEL=gemini-3.1-flash-lite

# Random generated token with `openssl rand -hex 32` to keep backend and db alive
KEEP_ALIVE_TOKEN=any-token

# Local development database.
# Used by the PostgreSQL container when running with Spring Boot Docker Compose support.

POSTGRES_DB=your-local-database
POSTGRES_USER=your-local-user
POSTGRES_PASSWORD=your-local-password

# Production datasource.
# Consumed by application-prod.yaml when the prod profile is active.

SPRING_DATASOURCE_URL=jdbc:postgresql://host:5432/database
SPRING_DATASOURCE_USERNAME=your-production-user
SPRING_DATASOURCE_PASSWORD=your-production-password